---
interface Props {
  date: Date;
  class?: string;
}
const { date, class: className = '' } = Astro.props;
const formatted = new Intl.DateTimeFormat('zh-CN', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
}).format(date);
---

<time datetime={date.toISOString()} class={className}>
  {formatted}
</time>
