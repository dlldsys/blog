---
interface Props {
  color?: 'marigold' | 'coral' | 'sky-wash' | 'mocha' | 'saffron' | 'vermillion' | 'accent';
  class?: string;
}
const { color = 'marigold', class: className = '' } = Astro.props;
const colorMap: Record<string, string> = {
  'marigold': 'background: #ffb110; color: #000;',
  'coral': 'background: #f64932; color: #fff;',
  'sky-wash': 'background: #62aef0; color: #000;',
  'mocha': 'background: #b18164; color: #fff;',
  'saffron': 'background: #e89d01; color: #000;',
  'vermillion': 'background: #e32d14; color: #fff;',
  'accent': 'background: var(--c-accent); color: var(--c-surface);',
};
---

<div class={`p-6 ${className}`} style={`border-radius: var(--r-card); ${colorMap[color]}`}>
  <slot />
</div>
