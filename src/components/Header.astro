---
import { NAV_LINKS, SITE_TITLE } from '@consts';

const currentPath = Astro.url.pathname;
const isActive = (href: string) => {
  if (href === '/') return currentPath === '/';
  return currentPath.startsWith(href);
};
---

<header
  class="fixed top-0 left-0 right-0 z-50 h-14 backdrop-blur-sm border-b"
  style="background: color-mix(in srgb, var(--c-bg) 90%, transparent); border-color: var(--c-border);"
>
  <div class="mx-auto flex h-full max-w-[900px] items-center justify-between px-6">
    <a
      href="/"
      class="font-semibold text-[15px] tracking-tight"
      style="color: var(--c-text);"
    >
      {SITE_TITLE}
    </a>

    <nav class="hidden md:flex items-center gap-6">
      {NAV_LINKS.map((link) => (
        <a
          href={link.href}
          class="relative text-sm transition-colors duration-200"
          style={isActive(link.href) ? 'color: var(--c-text); font-weight: 500;' : 'color: color-mix(in srgb, var(--c-text) 50%, transparent);'}
          onmouseover={isActive(link.href) ? '' : 'this.style.color="var(--c-text)"'}
          onmouseout={isActive(link.href) ? '' : 'this.style.color="color-mix(in srgb, var(--c-text) 50%, transparent)"'}
        >
          {link.label}
          {isActive(link.href) && (
            <span class="absolute -bottom-[18px] left-0 right-0 h-[2px] rounded-full" style="background: var(--c-text);"></span>
          )}
        </a>
      ))}
    </nav>

    <button
      id="mobile-nav-toggle"
      class="md:hidden inline-flex items-center justify-center w-9 h-9 -mr-2"
      style="color: var(--c-text);"
      aria-label="菜单"
    >
      <svg width="18" height="18" viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
        <line x1="3" y1="5" x2="15" y2="5" />
        <line x1="3" y1="9" x2="15" y2="9" />
        <line x1="3" y1="13" x2="15" y2="13" />
      </svg>
    </button>
  </div>

  <div
    id="mobile-nav"
    class="md:hidden hidden border-t"
    style="background: var(--c-bg); border-color: var(--c-border);"
  >
    <nav class="flex flex-col px-6 py-3">
      {NAV_LINKS.map((link) => (
        <a
          href={link.href}
          class="py-2.5 text-sm transition-colors duration-200"
          style={isActive(link.href) ? 'color: var(--c-text); font-weight: 500;' : 'color: color-mix(in srgb, var(--c-text) 50%, transparent);'}
        >
          {link.label}
        </a>
      ))}
    </nav>
  </div>
</header>

<script>
  const toggle = document.getElementById('mobile-nav-toggle');
  const mobileNav = document.getElementById('mobile-nav');
  toggle?.addEventListener('click', () => {
    mobileNav?.classList.toggle('hidden');
  });
</script>
