---
interface Props {
  title: string;
  subtitle?: string;
  align?: 'left' | 'center';
  class?: string;
}
const { title, subtitle, align = 'left', class: className = '' } = Astro.props;
---

<div class={`flex flex-col gap-2 ${align === 'center' ? 'items-center text-center' : 'items-start'} ${className}`}>
  <h2
    class="font-semibold text-ink-black"
    style="font-size: var(--text-heading-lg); line-height: 1.04; letter-spacing: -1.89px;"
  >
    {title}
  </h2>
  {subtitle && (
    <p
      class="font-lyon-text text-graphite"
      style="font-size: 18px; line-height: 1.56;"
    >
      {subtitle}
    </p>
  )}
</div>
