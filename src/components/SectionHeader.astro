---
interface Props {
  title: string;
  subtitle?: string;
  align?: 'left' | 'center';
  class?: string;
}
const { title, subtitle, align = 'left', class: className = '' } = Astro.props;
---

<div class={`flex flex-col gap-3 ${align === 'center' ? 'items-center text-center' : 'items-start'} ${className}`}>
  <h2 class="text-heading-lg text-ink-black">
    {title}
  </h2>
  {subtitle && (
    <p class="font-serif text-graphite text-lg leading-relaxed">
      {subtitle}
    </p>
  )}
</div>
