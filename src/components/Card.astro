---
interface Props {
  class?: string;
  as?: string;
}
const { class: className = '', as: Tag = 'div' } = Astro.props;
---

<Tag
  class={`border p-6 transition-all duration-200 ease-out ${className}`}
  style={`background: var(--c-surface); border-color: var(--c-border); border-radius: var(--r-card);`}
>
  <slot />
</Tag>
