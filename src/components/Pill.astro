---
interface Props {
  color?: 'marigold' | 'coral' | 'sky-wash' | 'sky-tint' | 'midnight-ink' | 'mocha' | 'saffron' | 'vermillion' | 'accent' | 'accent-soft';
  class?: string;
}
const { color = 'accent-soft', class: className = '' } = Astro.props;
const colorMap: Record<string, string> = {
  'marigold': 'background: #ffb110; color: #000;',
  'coral': 'background: #f64932; color: #fff;',
  'sky-wash': 'background: #62aef0; color: #000;',
  'sky-tint': 'background: #e6f3fe; color: #0075de;',
  'midnight-ink': 'background: #02093a; color: #fff;',
  'mocha': 'background: #b18164; color: #fff;',
  'saffron': 'background: #e89d01; color: #000;',
  'vermillion': 'background: #e32d14; color: #fff;',
  'accent': 'background: var(--c-accent); color: var(--c-surface);',
  'accent-soft': 'background: var(--c-accent-soft); color: var(--c-accent);',
};
---

<span
  class={`inline-flex items-center rounded-full px-3 py-1 text-xs font-medium ${className}`}
  style={colorMap[color]}
>
  <slot />
</span>
