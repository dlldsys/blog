---
interface Props {
  href?: string;
  class?: string;
}
const { href, class: className = '' } = Astro.props;
const Tag = href ? 'a' : 'button';
---

<Tag
  href={href}
  class={`inline-flex items-center justify-center gap-2 rounded-lg px-4 py-1.5 text-sm font-medium transition-all duration-200 ease-out active:scale-[0.98] ${className}`}
  style="background: var(--c-accent-soft); color: var(--c-accent);"
  onmouseover="this.style.opacity='0.8'"
  onmouseout="this.style.opacity='1'"
>
  <slot />
</Tag>
