---
import BaseLayout from '@layouts/BaseLayout.astro';
import PostListItem from '@components/PostListItem.astro';
import SectionHeader from '@components/SectionHeader.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const allTags = [...new Set(posts.flatMap((post) => post.data.tags))].sort();
---

<BaseLayout title="所有文章 — Notion 风格博客" description="所有博客文章列表">
  <section class="mx-auto max-w-[1440px] px-6 pt-16 pb-8">
    <SectionHeader
      title="所有文章"
      subtitle={`${posts.length} 篇文章`}
    />
  </section>

  <section class="mx-auto max-w-[1440px] px-6 pb-8">
    <div class="flex flex-wrap gap-2">
      <a
        href="/blog"
        class="rounded-full px-3 py-1 text-xs font-medium bg-ink-black text-pure-white"
      >
        全部
      </a>
      {allTags.map((tag) => (
        <a
          href={`/tags/${tag}/`}
          class="rounded-full px-3 py-1 text-xs font-medium bg-sky-tint text-notion-blue hover:bg-sky-wash/30 transition-colors duration-200"
        >
          {tag}
        </a>
      ))}
    </div>
  </section>

  <section class="mx-auto max-w-[1440px] px-6 pb-16">
    <div class="flex flex-col gap-4">
      {posts.map((post) => (
        <PostListItem post={post} />
      ))}
    </div>
  </section>
</BaseLayout>
