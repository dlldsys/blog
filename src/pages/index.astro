---
import BaseLayout from '@layouts/BaseLayout.astro';
import PostCard from '@components/PostCard.astro';
import SectionHeader from '@components/SectionHeader.astro';
import AccentCard from '@components/AccentCard.astro';
import PrimaryButton from '@components/PrimaryButton.astro';
import GhostButton from '@components/GhostButton.astro';
import Pill from '@components/Pill.astro';
import { getCollection } from 'astro:content';
import { SITE_TITLE, SITE_DESCRIPTION } from '@consts';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);
---

<BaseLayout title={SITE_TITLE} description={SITE_DESCRIPTION}>
  <section class="mx-auto max-w-[1440px] px-6 pt-20 pb-16 text-center">
    <div class="flex justify-center mb-6">
      <Pill color="sky-tint">技术博客</Pill>
    </div>

    <h1
      class="font-medium text-ink-black mb-6"
      style="font-size: var(--text-display); line-height: 1.04; letter-spacing: -2.016px;"
    >
      分享
      <span class="inline-block rounded-full bg-marigold px-6 py-1.5 align-middle">
        技术
      </span>
      与
      <span class="inline-block rounded-full bg-coral px-6 py-1.5 text-pure-white align-middle">
        思考
      </span>
    </h1>

    <p
      class="mx-auto max-w-[600px] font-lyon-text text-graphite mb-8"
      style="font-size: 18px; line-height: 1.56;"
    >
      一个温暖的、纸质感的博客空间，记录技术探索与设计思考。
    </p>

    <div class="flex justify-center gap-3">
      <PrimaryButton href="/blog">阅读文章</PrimaryButton>
      <GhostButton href="/about">关于我</GhostButton>
    </div>
  </section>

  <section class="mx-auto max-w-[1440px] px-6 py-16">
    <div class="flex items-center justify-between mb-8">
      <SectionHeader title="最新文章" />
      <a
        href="/blog"
        class="text-sm font-medium text-notion-blue hover:underline"
      >
        查看全部 →
      </a>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {posts.map((post) => (
        <PostCard post={post} />
      ))}
    </div>
  </section>

  <section class="mx-auto max-w-[1440px] px-6 py-16">
    <AccentCard color="marigold" class="p-12">
      <div class="max-w-[600px]">
        <h2
          class="font-medium text-ink-black mb-4"
          style="font-size: var(--text-heading); line-height: 1.5;"
        >
          为什么写博客？
        </h2>
        <p class="text-base text-ink-black/70 mb-6" style="line-height: 1.5;">
          写作是最好的学习方式。通过把复杂的技术概念用简单的语言表达出来，既能加深自己的理解，也能帮助到更多走在同一条路上的人。
        </p>
        <a
          href="/about"
          class="inline-flex items-center gap-2 text-sm font-medium text-ink-black hover:underline"
        >
          了解更多 →
        </a>
      </div>
    </AccentCard>
  </section>
</BaseLayout>
