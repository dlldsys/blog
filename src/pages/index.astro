---
import BaseLayout from '@layouts/BaseLayout.astro';
import PostCard from '@components/PostCard.astro';
import AccentCard from '@components/AccentCard.astro';
import PrimaryButton from '@components/PrimaryButton.astro';
import GhostButton from '@components/GhostButton.astro';
import Pill from '@components/Pill.astro';
import { getCollection } from 'astro:content';
import { SITE_TITLE, SITE_DESCRIPTION } from '@consts';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);
---

<BaseLayout title={SITE_TITLE} description={SITE_DESCRIPTION}>
  <!-- Hero -->
  <section class="px-6 pt-20 pb-20 md:pt-28 md:pb-24">
    <div class="max-w-[900px] mx-auto">
      <div class="animate-fade-in-up" style="animation-delay: 0ms;">
        <Pill color="sky-tint">技术博客</Pill>
      </div>

      <h1 class="text-display text-ink-black mt-6 mb-6 animate-fade-in-up" style="animation-delay: 80ms;">
        分享
        <span class="inline-block rounded-full bg-marigold px-5 py-0.5 align-baseline">
          技术
        </span>
        与
        <span class="inline-block rounded-full bg-coral px-5 py-0.5 text-pure-white align-baseline">
          思考
        </span>
      </h1>

      <p class="font-serif text-graphite text-lg md:text-xl leading-relaxed max-w-[560px] mb-10 animate-fade-in-up" style="animation-delay: 160ms;">
        一个温暖的、纸质感的博客空间，记录技术探索与设计思考。
      </p>

      <div class="flex gap-3 animate-fade-in-up" style="animation-delay: 240ms;">
        <PrimaryButton href="/blog">阅读文章</PrimaryButton>
        <GhostButton href="/about">关于我</GhostButton>
      </div>
    </div>
  </section>

  <!-- Latest Posts -->
  <section class="px-6 py-16">
    <div class="max-w-[1200px] mx-auto">
      <div class="flex items-end justify-between mb-10">
        <h2 class="text-heading-lg text-ink-black">最新文章</h2>
        <a
          href="/blog"
          class="text-sm font-medium text-notion-blue hover:underline shrink-0"
        >
          查看全部 →
        </a>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
        {posts.map((post, i) => (
          <PostCard post={post} class="animate-fade-in-up" />
        ))}
      </div>
    </div>
  </section>

  <!-- About Accent Section -->
  <section class="px-6 py-16">
    <div class="max-w-[1200px] mx-auto">
      <AccentCard color="marigold" class="p-10 md:p-14">
        <div class="max-w-[560px]">
          <h2 class="text-heading text-ink-black mb-4">
            为什么写博客？
          </h2>
          <p class="text-body text-ink-black/70 mb-6 leading-relaxed">
            写作是最好的学习方式。通过把复杂的技术概念用简单的语言表达出来，既能加深自己的理解，也能帮助到更多走在同一条路上的人。
          </p>
          <a
            href="/about"
            class="inline-flex items-center gap-1.5 text-sm font-medium text-ink-black hover:gap-2.5 transition-all duration-200"
          >
            了解更多 →
          </a>
        </div>
      </AccentCard>
    </div>
  </section>
</BaseLayout>
