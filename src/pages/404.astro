---
import BaseLayout from '@layouts/BaseLayout.astro';
import PrimaryButton from '@components/PrimaryButton.astro';
---

<BaseLayout title="404 — 页面未找到" description="页面未找到">
  <section class="mx-auto max-w-[800px] px-6 pt-32 pb-32 text-center">
    <h1
      class="font-semibold text-ink-black mb-4"
      style="font-size: var(--text-display-lg); line-height: 1.04; letter-spacing: -4.608px;"
    >
      404
    </h1>
    <p
      class="font-lyon-text text-graphite mb-8 mx-auto"
      style="font-size: 18px; line-height: 1.56;"
    >
      这个页面不存在，也许从未存在过。
    </p>
    <PrimaryButton href="/">返回首页</PrimaryButton>
  </section>
</BaseLayout>
