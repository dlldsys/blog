---
import BaseLayout from '@layouts/BaseLayout.astro';
import PrimaryButton from '@components/PrimaryButton.astro';
---

<BaseLayout title="404 — 页面未找到" description="页面未找到">
  <section class="max-w-[800px] mx-auto px-6 pt-32 pb-32 text-center">
    <h1 class="text-display-lg mb-4" style="color: var(--c-text);">
      404
    </h1>
    <p class="font-serif text-lg mb-8" style="color: var(--c-text-soft);">
      这个页面不存在，也许从未存在过。
    </p>
    <PrimaryButton href="/">返回首页</PrimaryButton>
  </section>
</BaseLayout>
