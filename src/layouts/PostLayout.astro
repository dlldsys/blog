---
import BaseLayout from './BaseLayout.astro';
import FormattedDate from '@components/FormattedDate.astro';
import Pill from '@components/Pill.astro';
import Comments from '@components/Comments.astro';
import type { CollectionEntry } from 'astro:content';

interface Props {
  post: CollectionEntry<'blog'>;
  prev?: { slug: string; title: string };
  next?: { slug: string; title: string };
}

const { post, prev, next } = Astro.props;
const { title, description, pubDate, updatedDate, tags } = post.data;
const tagColors = ['marigold', 'coral', 'sky-wash', 'mocha'] as const;

const content = post.body ?? '';
const wordsPerMinute = 300;
const wordCount = content.split(/\s+/).filter(Boolean).length;
const readingTime = Math.max(1, Math.ceil(wordCount / wordsPerMinute));
---

<BaseLayout title={`${title} — Notion 风格博客`} description={description}>
  <article>
    <header class="max-w-[720px] mx-auto px-6 pt-16 pb-10">
      <div class="flex flex-wrap gap-2 mb-6">
        {tags.map((tag, i) => (
          <a href={`/tags/${tag}/`}>
            <Pill color={tagColors[i % tagColors.length]}>{tag}</Pill>
          </a>
        ))}
      </div>

      <h1 class="text-display-sm mb-4" style="color: var(--c-text);">
        {title}
      </h1>

      <p class="font-serif text-lg leading-relaxed mb-6" style="color: var(--c-text-soft);">
        {description}
      </p>

      <div class="flex items-center gap-3 text-sm" style="color: color-mix(in srgb, var(--c-text) 40%, transparent);">
        <FormattedDate date={pubDate} />
        <span>·</span>
        <span>{readingTime} 分钟阅读</span>
        {updatedDate && (
          <>
            <span>·</span>
            <span>更新于 <FormattedDate date={updatedDate} /></span>
          </>
        )}
      </div>
    </header>

    <div class="prose px-6 pb-12">
      <slot />
    </div>

    {(prev || next) && (
      <nav class="max-w-[720px] mx-auto px-6 py-8 border-t" style="border-color: var(--c-border);">
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          {prev ? (
            <a
              href={`/blog/${prev.slug}/`}
              class="border p-5 transition-all duration-200 group"
              style="background: var(--c-surface); border-color: var(--c-border); border-radius: var(--r-card);"
              onmouseover="this.style.borderColor='color-mix(in srgb, var(--c-text) 15%, transparent)'"
              onmouseout="this.style.borderColor='var(--c-border)'"
            >
              <span class="text-xs" style="color: color-mix(in srgb, var(--c-text) 40%, transparent);">← 上一篇</span>
              <p class="text-sm font-medium mt-1.5" style="color: var(--c-text);">
                {prev.title}
              </p>
            </a>
          ) : <div />}
          {next ? (
            <a
              href={`/blog/${next.slug}/`}
              class="border p-5 text-right transition-all duration-200 group"
              style="background: var(--c-surface); border-color: var(--c-border); border-radius: var(--r-card);"
              onmouseover="this.style.borderColor='color-mix(in srgb, var(--c-text) 15%, transparent)'"
              onmouseout="this.style.borderColor='var(--c-border)'"
            >
              <span class="text-xs" style="color: color-mix(in srgb, var(--c-text) 40%, transparent);">下一篇 →</span>
              <p class="text-sm font-medium mt-1.5" style="color: var(--c-text);">
                {next.title}
              </p>
            </a>
          ) : <div />}
        </div>
      </nav>
    )}

    <div class="px-6 pb-16">
      <Comments />
    </div>
  </article>
</BaseLayout>
